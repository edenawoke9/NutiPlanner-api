DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/nutplanner"
SECRET_KEY="replace-with-a-strong-secret"
# Optional path to Ethiopian food CSV (defaults to project root file)
# FOOD_CSV_PATH="./ethiopian_food_nutrition_300.csv"

# Used by /chat/message only (meal plans use stochastic matching, not Gemini)
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="gemini-1.5-flash"

# Daily meal plan cron (default: 5:00 AM). Set ENABLE_DAILY_MEAL_PLAN_CRON=false to disable.
# MEAL_PLAN_CRON="0 5 * * *"
# MEAL_PLAN_CRON_TZ="Africa/Addis_Ababa"